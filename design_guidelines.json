  "instructions_to_main_agent": [
    "Install 'lucide-react' for icons: `yarn add lucide-react`.",
    "Install 'framer-motion' for animations: `yarn add framer-motion`.",
    "Install 'recharts' for charts: `yarn add recharts`.",
    "Install 'react-dropzone' for file uploads: `yarn add react-dropzone`.",
    "Configure Tailwind themes by extending `theme.colors` with the palette provided above in `tailwind.config.js`.",
    "For the Logo: Use a text logo 'Fruitee' with the 'i' replaced by an SVG of a fruit (orange/peach) or a colored dot.",
    "Implement the 'Digital Twin' recording UI with a clear visualizer component.",
    "Use Bento Grid layouts for the Dashboard.",
    "Ensure all interactive elements have `data-testid` attributes."
  ],
  "universal_guidelines": [
    "Do not use generic gray backgrounds; always tint with warm cream (#FFF8F0).",
    "Avoid sharp edges; use `rounded-2xl` or `rounded-3xl`.",
    "Use gradients sparingly (buttons, text highlights), not full backgrounds.",
    "Ensure all text meets APCA contrast standards against the cream background.",
    "Micro-interactions: Buttons should scale down slightly on click (`active:scale-95`)."
  ]
}